{
  "name": "@liftkit-vue/nuxt",
  "version": "0.1.0",
  "description": "Nuxt 4 module for LiftKit Vue - auto-imports components and CSS design tokens",
  "type": "module",
  "license": "MIT",
  "author": "annrie",
  "repository": {
    "type": "git",
    "url": "https://github.com/annrie/liftkit-vue",
    "directory": "packages/nuxt"
  },
  "homepage": "https://github.com/annrie/liftkit-vue/tree/main/packages/nuxt",
  "bugs": "https://github.com/annrie/liftkit-vue/issues",
  "keywords": [
    "nuxt",
    "nuxt4",
    "nuxt-module",
    "vue",
    "material-design",
    "md3",
    "design-system",
    "liftkit"
  ],
  "main": "./dist/module.mjs",
  "exports": {
    ".": {
      "import": "./dist/module.mjs",
      "types": "./dist/types.d.mts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "nuxt-module-build build",
    "typecheck": "vue-tsc --noEmit"
  },
  "dependencies": {
    "@liftkit-vue/core": "workspace:*",
    "@nuxt/kit": "^4.3.1"
  },
  "devDependencies": {
    "@nuxt/module-builder": "^1.0.2",
    "@nuxt/schema": "^4.3.1",
    "nuxt": "^4.3.1",
    "vue": "^3.5.0",
    "vue-tsc": "^2.2.0",
    "typescript": "^5.7.0"
  }
}
