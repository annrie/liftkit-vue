{
  "name": "@liftkit-vue/core",
  "version": "0.1.0",
  "description": "Material Design 3 inspired Vue 3 component library with dynamic theming and golden-ratio design tokens",
  "type": "module",
  "license": "MIT",
  "author": "annrie",
  "repository": {
    "type": "git",
    "url": "https://github.com/annrie/liftkit-vue",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/annrie/liftkit-vue/tree/main/packages/core",
  "bugs": "https://github.com/annrie/liftkit-vue/issues",
  "keywords": [
    "vue",
    "vue3",
    "material-design",
    "md3",
    "design-system",
    "components",
    "theming",
    "golden-ratio",
    "css-tokens"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./css/*": "./src/css/*"
  },
  "files": ["dist", "src/css"],
  "scripts": {
    "build": "vite build",
    "typecheck": "vue-tsc --noEmit"
  },
  "dependencies": {
    "@material/material-color-utilities": "^0.3.0",
    "material-dynamic-colors": "^1.1.2",
    "@floating-ui/vue": "^1.1.6",
    "@csstools/normalize.css": "^12.1.1"
  },
  "devDependencies": {
    "vue": "^3.5.0",
    "vite": "^6.0.0",
    "typescript": "^5.7.0",
    "@vitejs/plugin-vue": "^5.2.0",
    "vue-tsc": "^2.2.0"
  },
  "peerDependencies": {
    "vue": "^3.5.0"
  }
}
