    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@unocss/core": "^66.6.5"
  },
  "devDependencies": {
    "unbuild": "^3.6.1",
    "typescript": "^5.9.3",
    "unocss": "^66.6.5"
  }
}
